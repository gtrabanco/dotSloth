#!/usr/bin/env bash
# Run all bats tests
# Usage: scripts/self/test [bats-args...]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# Ensure bats-core is available
if ! command -v bats &> /dev/null; then
  echo "ERROR: bats-core not found. Install with:" >&2
  echo "  macOS: brew install bats-core" >&2
  echo "  Ubuntu: sudo apt-get install bats" >&2
  exit 1
fi

cd "$PROJECT_ROOT"
exec bats "$@" tests/
# test
